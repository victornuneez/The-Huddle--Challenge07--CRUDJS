<!DOCTYPE html>
<html lang="es">
<head>
    <title>Editar Tema</title>
</head>
<body>
    <h1>Editar el tema</h1>
    <form action="/temas/editar/<%= tema.id %>" method="POST">

        <label>Nombre del Tema:</label><br>
        <input type="text" name="titulo" value="<%= tema.titulo %>" required>

        <br><br>

        <label>Enlace (URL):</label><br>
        <input type="url" name="enlace" value="<%= tema.enlace %>" required>
        
        <br><br>

        <button type="submit">Guardar Cambios</button>
        <a href="/temas">Cancelar</a>
    </form>
</body>
</html>